{
  "name": "proactive",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "photos:process": "node scripts/process-photos.mjs",
    "redirects:verify": "node scripts/verify-redirects.mjs",
    "typegen": "sanity schema extract && sanity typegen generate",
    "postinstall": "node scripts/minify-sanity.mjs && node scripts/patch-next-react.mjs",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@mux/mux-player-react": "^3.11.8",
    "@next/third-parties": "^16.2.4",
    "@portabletext/react": "^6.0.3",
    "@react-email/components": "^1.0.12",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.22.0",
    "@sentry/nextjs": "^10.49.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "next-mdx-remote": "^6.0.0",
    "next-sanity": "^11.6.13",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "sanity": "^5.22.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.0.2",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^52.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "path-to-regexp": ">=8.4.0"
    }
  }
}
