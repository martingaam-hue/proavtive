# --- Sentry (Plan 05 — @sentry/nextjs wizard) ---
# Client-exposed DSN (safe — DSN is public by design). Read by sentry.client.config.ts.
NEXT_PUBLIC_SENTRY_DSN=
# Server-only DSN (same value; kept separate so the client bundle cannot accidentally leak server config).
SENTRY_DSN=
# Sentry auth token — server-only. Used by the Sentry webpack plugin for source-map upload on Vercel builds.
# Scope: project:releases + project:write. Rotate per PROJECT.md security discipline. NEVER commit.
SENTRY_AUTH_TOKEN=
# Sentry org slug (e.g. "proactiv-sports"). Used by the Sentry webpack plugin.
SENTRY_ORG=
# Sentry project slug (e.g. "proactive-web").
SENTRY_PROJECT=
# Shared secret for /api/sentry-smoke route (Plan 05 / D-19). Server-only.
# Generated: `openssl rand -hex 32`
SENTRY_SMOKE_TOKEN=

# --- Vercel (injected automatically at runtime; listed here for documentation) ---
# VERCEL_ENV=                  # production | preview | development (set by Vercel)
# VERCEL_GIT_COMMIT_SHA=       # set by Vercel — used for Sentry release tagging (D-17, D-18)

# --- Sanity (Plan 01-03 — embedded Studio wiring, D-09) ---
# Client-safe (public by design — read by next-sanity client + Studio mount at /studio).
# Get from Sanity dashboard → Settings → API → Project ID.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Client-safe. Phase 1–5 use 'production' only (D-10). Phase 6 may add 'development'.
NEXT_PUBLIC_SANITY_DATASET=production
# Server-only. Read-access token for draft/preview content + server fetches.
# Scope: Viewer. Rotate per PROJECT.md security discipline. NEVER commit.
# Get from Sanity dashboard → Settings → API → Tokens → Add API Token.
SANITY_API_READ_TOKEN=

# ────────────────────────────────────────────────────────────────
# Phase 3 — Root gateway + contact backend
# ────────────────────────────────────────────────────────────────

# Cross-subdomain market URLs (NEXT_PUBLIC = client-readable, inlined at build).
# Production: https://hk.proactivsports.com/  |  Preview fallback: /?__market=hk
NEXT_PUBLIC_HK_URL=https://hk.proactivsports.com/
NEXT_PUBLIC_SG_URL=https://sg.proactivsports.com/

# Resend contact form backend (server-only — NEVER prefix with NEXT_PUBLIC_).
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Contact inbox routing (server-only). HK form → CONTACT_INBOX_HK; SG form → CONTACT_INBOX_SG.
CONTACT_INBOX_HK=
CONTACT_INBOX_SG=

# WhatsApp click-to-chat numbers (NEXT_PUBLIC = used in href construction at the client).
# Format: international with country code, NO spaces or dashes (e.g. +6598076827).
# SG number per strategy PART 8.3: +65 9807 6827.  HK number TBD by Martin.
NEXT_PUBLIC_WHATSAPP_HK=
NEXT_PUBLIC_WHATSAPP_SG=

# ────────────────────────────────────────────────────────────────
# Phase 4 — Hong Kong market (Plan 04-01)
# ────────────────────────────────────────────────────────────────
# HUMAN-ACTION: populate all values below before shipping HK pages to production.
# All NEXT_PUBLIC_* vars below are client-bundle-visible by design (public artefacts
# of the business — Mux playback IDs, phone numbers, map embed URLs).

# Mux playback ID for the HK homepage hero video (D-01 — CONTEXT.md).
# Phase 4 scaffolds the <VideoPlayer> with a poster fallback; real playback ID is
# attached before public ship. Get from Mux dashboard → Assets → copy playback ID.
NEXT_PUBLIC_MUX_HK_HERO_PLAYBACK_ID=

# HK venue phone numbers (shared default + optional Cyberport override).
# Format: international with country code, NO spaces or dashes (e.g. +85212345678).
NEXT_PUBLIC_HK_PHONE=
NEXT_PUBLIC_HK_WHATSAPP=
# Optional: separate phone line for Cyberport venue (if distinct from shared HK number).
NEXT_PUBLIC_HK_PHONE_CYBERPORT=

# Cross-subdomain URLs (used for HK→Root and HK→SG links via absolute <a href>).
# Production: https://proactivsports.com/ / https://sg.proactivsports.com/
NEXT_PUBLIC_ROOT_URL=
# (NEXT_PUBLIC_SG_URL declared above in the Phase 3 block — reuse the same var.)

# Google Maps embed URLs for the two HK location pages (D-04, Research Pattern 3).
# Get from: maps.google.com → search venue → Share → Embed a map → copy src=... URL.
NEXT_PUBLIC_WAN_CHAI_MAP_EMBED=
NEXT_PUBLIC_CYBERPORT_MAP_EMBED=

# ────────────────────────────────────────────────────────────────
# Phase 5 — Singapore market (Plan 05-01)
# ────────────────────────────────────────────────────────────────
# HUMAN-ACTION: populate all values below before shipping SG pages to production.
# All NEXT_PUBLIC_* vars below are client-bundle-visible by design (public artefacts
# of the business — Mux playback IDs, WhatsApp number, map embed URLs).

# Resend inbox for SG booking/contact submissions.
# Already wired in /api/contact since Phase 3 (CONTACT_INBOX_SG above).
# Documented here for Phase 5 operator reference — set the same var as above.
CONTACT_INBOX_SG=

# WhatsApp number for SG CTA chip (per strategy PART 8.3).
# Format: E.164 without +, e.g. 6598076827. Already declared in Phase 3 block above.
# Documented here for Phase 5 operator reference — set the same var as above.
NEXT_PUBLIC_WHATSAPP_SG=

# Mux playback ID for the SG homepage hero video montage (D-07 gate).
# Phase 5 scaffolds the <VideoPlayer> with a poster fallback; real playback ID is
# attached before public ship. Leave empty to fall back to poster image.
# Get from Mux dashboard → Assets → copy playback ID.
NEXT_PUBLIC_MUX_SG_HERO_PLAYBACK_ID=

# Google Maps embed URL for Prodigy @ Katong Point (451 Joo Chiat Road, Level 3).
# Get from: maps.google.com → search "451 Joo Chiat Road, Level 3, Singapore" →
#   Share → Embed a map → copy the src="..." URL from the iframe code.
# HUMAN-ACTION D-07: generate this at execute-time and add to Vercel env vars.
NEXT_PUBLIC_MAP_EMBED_KATONG_POINT=

# Cross-market links rendered as absolute <a href> (never <Link> — cross-subdomain).
# Production: https://hk.proactivsports.com/ / https://proactivsports.com/
# Already declared in Phase 3 and Phase 4 blocks above — documented here for Phase 5 reference.
NEXT_PUBLIC_HK_URL=
NEXT_PUBLIC_ROOT_URL=
