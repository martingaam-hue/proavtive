# --- Sentry (Plan 05 — @sentry/nextjs wizard) ---
# Client-exposed DSN (safe — DSN is public by design). Read by sentry.client.config.ts.
NEXT_PUBLIC_SENTRY_DSN=
# Server-only DSN (same value; kept separate so the client bundle cannot accidentally leak server config).
SENTRY_DSN=
# Sentry auth token — server-only. Used by the Sentry webpack plugin for source-map upload on Vercel builds.
# Scope: project:releases + project:write. Rotate per PROJECT.md security discipline. NEVER commit.
SENTRY_AUTH_TOKEN=
# Sentry org slug (e.g. "proactiv-sports"). Used by the Sentry webpack plugin.
SENTRY_ORG=
# Sentry project slug (e.g. "proactive-web").
SENTRY_PROJECT=
# Shared secret for /api/sentry-smoke route (Plan 05 / D-19). Server-only.
# Generated: `openssl rand -hex 32`
SENTRY_SMOKE_TOKEN=

# --- Vercel (injected automatically at runtime; listed here for documentation) ---
# VERCEL_ENV=                  # production | preview | development (set by Vercel)
# VERCEL_GIT_COMMIT_SHA=       # set by Vercel — used for Sentry release tagging (D-17, D-18)

# --- Sanity (Plan 01-03 — embedded Studio wiring, D-09) ---
# Client-safe (public by design — read by next-sanity client + Studio mount at /studio).
# Get from Sanity dashboard → Settings → API → Project ID.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Client-safe. Phase 1–5 use 'production' only (D-10). Phase 6 may add 'development'.
NEXT_PUBLIC_SANITY_DATASET=production
# Server-only. Read-access token for draft/preview content + server fetches.
# Scope: Viewer. Rotate per PROJECT.md security discipline. NEVER commit.
# Get from Sanity dashboard → Settings → API → Tokens → Add API Token.
SANITY_API_READ_TOKEN=

# ────────────────────────────────────────────────────────────────
# Phase 3 — Root gateway + contact backend
# ────────────────────────────────────────────────────────────────

# Cross-subdomain market URLs (NEXT_PUBLIC = client-readable, inlined at build).
# Production: https://hk.proactivsports.com/  |  Preview fallback: /?__market=hk
NEXT_PUBLIC_HK_URL=https://hk.proactivsports.com/
NEXT_PUBLIC_SG_URL=https://sg.proactivsports.com/

# Resend contact form backend (server-only — NEVER prefix with NEXT_PUBLIC_).
# Get from: https://resend.com/api-keys
RESEND_API_KEY=

# Contact inbox routing (server-only). HK form → CONTACT_INBOX_HK; SG form → CONTACT_INBOX_SG.
CONTACT_INBOX_HK=
CONTACT_INBOX_SG=

# WhatsApp click-to-chat numbers (NEXT_PUBLIC = used in href construction at the client).
# Format: international with country code, NO spaces or dashes (e.g. +6598076827).
# SG number per strategy PART 8.3: +65 9807 6827.  HK number TBD by Martin.
NEXT_PUBLIC_WHATSAPP_HK=
NEXT_PUBLIC_WHATSAPP_SG=
